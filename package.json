{
  "name": "legion",
  "version": "0.1.0",
  "description": "Group intelligence AI agent",
  "homepage": "https://github.com/anaplian-io/legion#readme",
  "bugs": {
    "url": "https://github.com/anaplian-io/legion/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anaplian-io/legion.git"
  },
  "license": "MIT",
  "author": "Ethan Fortner",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest --run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules coverage src/**/*.guard.ts data/*.json mcp.json",
    "lint": "eslint . && prettier --check .",
    "format": "eslint . --fix && prettier --write .",
    "prepare": "husky",
    "release": "npm ci && npm run lint && npm run build && npm run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "openai": "^6.7.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  }
}
