{
  "name": "legion",
  "version": "0.1.0",
  "description": "Group intelligence AI agent",
  "homepage": "https://github.com/anaplian-io/legion#readme",
  "bugs": {
    "url": "https://github.com/anaplian-io/legion/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anaplian-io/legion.git"
  },
  "license": "MIT",
  "author": "Ethan Fortner",
  "type": "module",
  "scripts": {
    "prebuild": "[ -f settings.ts ] && echo 'settings.ts already exists, skipping copy' || (cp settings.example.ts settings.ts && echo 'Created settings.ts from settings.example.ts')",
    "build": "tsc",
    "test": "vitest --run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules coverage settings.ts",
    "lint": "eslint . && prettier --check .",
    "format": "eslint . --fix && prettier --write .",
    "prepare": "husky",
    "release": "npm ci && npm run lint && npm run build && npm run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.7.0",
    "p-queue": "^9.3.0",
    "p-retry": "^8.0.0",
    "p-timeout": "^7.0.1"
  }
}
